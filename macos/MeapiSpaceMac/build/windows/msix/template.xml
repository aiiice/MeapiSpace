<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="meapispacemac.exe"
        Arguments=""
        InstallLocation="C:\Program Files\MeapiSpace\MeapiSpace">
    </Installer>
    <PackageInformation
        PackageName="MeapiSpace"
        PackageDisplayName="MeapiSpace"
        PublisherName="CN=MeapiSpace"
        PublisherDisplayName="MeapiSpace"
        Version="0.1.0.0"
        PackageDescription="MeapiSpace macOS quota widget">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="space.meapi.widget"
                Description="MeapiSpace macOS quota widget"
                DisplayName="MeapiSpace"
                ExecutableName="meapispacemac.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>MeapiSpace</DisplayName>
            <PublisherDisplayName>MeapiSpace</PublisherDisplayName>
            <Description>MeapiSpace macOS quota widget</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="meapispacemac.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
